# Terraform state files
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform variables (contains secrets)
*.tfvars
!*.tfvars.example

# Terraform directory
.terraform/
.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# AWS credentials (should never be committed)
.aws/
*.pem
*.key

# OS files
.DS_Store
Thumbs.db

# Editor files
*.swp
*.swo
*~
.idea/
.vscode/
