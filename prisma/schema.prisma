// Coalition X - Database Schema
// ZIA KPI Tracking Platform for Real Estate Sustainability

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// Core Multi-Tenant Models
// =============================================================================

model Organization {
  id     String    @id @default(cuid())
  name   String
  type   OrgType
  status OrgStatus @default(ACTIVE)

  // OAuth 2.0 Client Credentials
  clientId         String  @unique @default(cuid())
  clientSecretHash String?

  // Legacy API key (deprecated, use OAuth)
  apiKey     String? @unique
  apiKeyHash String?

  users          User[]
  assets         Asset[]
  kpiRecords     KpiRecord[]
  apiTokens      ApiToken[]
  auditLogs      AuditLog[]
  submissions    Submission[]
  webhooks       WebhookConfig[]
  partnerRequest PartnerRequest?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([apiKey])
  @@index([status])
  @@index([type])
}

model Asset {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  externalId  String?
  name        String?
  address     String?
  description String?

  dataSource   DataSource @default(MANUAL)
  sourceTag    SourceTag  @default(MANUAL)
  submittedVia String?

  kpiRecords      KpiRecord[]
  signedDocuments SignedDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, externalId])
  @@index([organizationId])
  @@index([name])
  @@index([externalId])
}

// =============================================================================
// KPI Data Storage
// =============================================================================

model SchemaRegistry {
  id          String  @id @default(cuid())
  version     String  @unique
  name        String?
  description String?
  schema    Json
  checksum  String?
  isActive  Boolean @default(true)

  changelog    String?
  deprecatedAt DateTime?

  kpiRecords KpiRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([version])
  @@index([checksum])
}

model ValidationRule {
  id      String @id @default(cuid())
  name    String
  version Int    @default(1)
  rules   Json

  isActive  Boolean @default(false)
  isDefault Boolean @default(false)

  previousVersionId String?
  previousVersion   ValidationRule?  @relation("RuleVersionChain", fields: [previousVersionId], references: [id])
  nextVersions      ValidationRule[] @relation("RuleVersionChain")

  description String?
  changedBy   String?
  changeNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, version])
  @@index([isActive])
  @@index([name, isActive])
}

model KpiRecord {
  id              String  @id @default(cuid())
  assetId         String
  organizationId  String
  submissionId    String? @unique
  dataVersion     Int
  schemaVersionId String
  kpiData         Json
  checksum        String?
  externalAssetId String?

  asset          Asset          @relation(fields: [assetId], references: [id], onDelete: Cascade)
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  submission     Submission?    @relation(fields: [submissionId], references: [id])
  schemaRegistry SchemaRegistry @relation(fields: [schemaVersionId], references: [id])

  validationStatus ValidationStatus @default(PENDING)
  validationErrors Json?
  source           DataSource       @default(API)

  createdAt DateTime @default(now())

  @@unique([assetId, dataVersion])
  @@index([assetId, createdAt])
  @@index([organizationId, createdAt])
  @@index([schemaVersionId])
  @@index([validationStatus])
  @@index([checksum])
}

// =============================================================================
// User & Authentication
// =============================================================================

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  role          UserRole
  passwordHash  String
  emailVerified Boolean  @default(false)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  apiTokens   ApiToken[]
  auditLogs   AuditLog[]
  submissions Submission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([email])
}

model ApiToken {
  id        String @id @default(cuid())
  token     String @unique
  tokenHash String

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  name   String?
  scopes String[]

  expiresAt        DateTime
  refreshToken     String?   @unique
  refreshExpiresAt DateTime?

  lastUsedAt DateTime?
  lastUsedIp String?
  usageCount Int       @default(0)

  revoked   Boolean   @default(false)
  revokedAt DateTime?
  revokedBy String?

  createdAt DateTime @default(now())

  @@index([token])
  @@index([organizationId])
  @@index([expiresAt])
  @@index([revoked])
}

// =============================================================================
// Audit & Submission Tracking
// =============================================================================

model AuditLog {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  action     AuditAction
  resource   String
  resourceId String?

  method     String?
  endpoint   String?
  statusCode Int?

  ipAddress      String?
  userAgent      String?
  requestHeaders Json?

  payload  Json?
  response Json?

  schemaVersion String?

  createdAt DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([resource, resourceId])
}

model Submission {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  submissionType SubmissionType
  resourceType   String
  resourceId     String?
  sourceTag      SourceTag      @default(MANUAL)

  status       SubmissionStatus @default(PENDING)
  totalRecords Int              @default(1)
  successCount Int              @default(0)
  failureCount Int              @default(0)

  validationStatus ValidationStatus @default(PENDING)
  validationErrors Json?
  errors           Json?
  warnings         Json?

  idempotencyKey String? @unique

  ipAddress      String?
  userAgent      String?
  requestPayload Json?
  responseTime   Int?

  kpiVersion String?
  ingestTime DateTime  @default(now())
  enrichedAt DateTime?

  batchItems        BatchSubmissionItem[]
  kpiRecord         KpiRecord?
  queueItem         QueueItem?
  fraunhoferRequest FraunhoferRequest?

  submittedAt DateTime  @default(now())
  completedAt DateTime?

  @@index([organizationId, submittedAt])
  @@index([status])
  @@index([validationStatus])
  @@index([idempotencyKey])
  @@index([sourceTag])
}

model BatchSubmissionItem {
  id           String     @id @default(cuid())
  submissionId String
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  itemIndex  Int
  externalId String?
  resourceId String?

  status      SubmissionStatus
  errors      Json?
  itemPayload Json

  createdAt DateTime @default(now())

  @@unique([submissionId, itemIndex])
  @@index([submissionId])
}

// =============================================================================
// Connector 2: Fraunhofer Integration
// =============================================================================

model QueueItem {
  id           String     @id @default(cuid())
  submissionId String     @unique
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  queueName   String      @default("fraunhofer")
  queueStatus QueueStatus @default(PENDING)
  priority    Int         @default(0)

  attemptCount Int       @default(0)
  maxAttempts  Int       @default(5)
  nextRetryAt  DateTime?
  lastError    String?

  queuedAt     DateTime  @default(now())
  processingAt DateTime?
  completedAt  DateTime?
  failedAt     DateTime?

  isDeadLetter     Boolean   @default(false)
  deadLetterAt     DateTime?
  deadLetterReason String?

  @@index([queueStatus, priority, queuedAt])
  @@index([queueName, queueStatus])
  @@index([isDeadLetter])
  @@index([nextRetryAt])
}

model FraunhoferRequest {
  id           String     @id @default(cuid())
  submissionId String     @unique
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  status          FraunhoferStatus @default(PENDING)
  requestPayload  Json?
  responsePayload Json?

  endpoint     String?
  statusCode   Int?
  errorMessage String?

  attemptCount  Int       @default(0)
  maxAttempts   Int       @default(3)
  lastAttemptAt DateTime?

  callbackId       String?  @unique
  callbackReceived Boolean  @default(false)
  pollCount        Int      @default(0)
  lastPolledAt     DateTime?

  computedAt DateTime?
  verified   Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([callbackId])
}

// =============================================================================
// Connector 3: Trust Layer Signing
// =============================================================================

model SigningRequest {
  id      String @id @default(cuid())
  assetId String

  status         SigningStatus @default(PENDING)
  requestPayload Json?

  trustLayerRequestId String? @unique
  holderIdentity      String?
  verifierDetails     Json?

  attemptCount  Int       @default(0)
  maxAttempts   Int       @default(3)
  lastAttemptAt DateTime?
  lastError     String?

  idempotencyKey   String? @unique
  requestDuration  Int?
  responseDuration Int?

  kpiVersion String?
  userId     String?
  systemId   String?

  consentGiven     Boolean   @default(false)
  consentTimestamp DateTime?

  signedDocument   SignedDocument? @relation(fields: [signedDocumentId], references: [id])
  signedDocumentId String?         @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assetId])
  @@index([status])
  @@index([trustLayerRequestId])
  @@index([idempotencyKey])
}

model SignedDocument {
  id      String @id @default(cuid())
  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  filename    String
  contentType String @default("application/pdf")
  fileSize    Int?
  storageUrl  String
  checksum    String?

  signedAt           DateTime
  signatureTimestamp DateTime?
  signerIdentity     String?
  signatureContext   Json?

  verified            Boolean   @default(false)
  verifiedAt          DateTime?
  verificationDetails Json?

  expiresAt DateTime?

  signingRequest SigningRequest?
  accessGrants   DocumentAccessGrant[]
  accessLogs     DocumentAccessLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assetId])
  @@index([signedAt])
  @@index([expiresAt])
}

// =============================================================================
// Connector 4: Document Distribution
// =============================================================================

model DocumentAccessGrant {
  id         String         @id @default(cuid())
  documentId String
  document   SignedDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  granteeType GranteeType
  granteeId   String
  granteeName String?

  grantedAt DateTime  @default(now())
  expiresAt DateTime?
  revokedAt DateTime?

  canDownload Boolean @default(true)
  canVerify   Boolean @default(true)

  dailyLimit   Int       @default(100)
  currentCount Int       @default(0)
  limitResetAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([documentId, granteeType, granteeId])
  @@index([granteeType, granteeId])
  @@index([documentId])
  @@index([expiresAt])
}

model DocumentAccessLog {
  id         String         @id @default(cuid())
  documentId String
  document   SignedDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  accessorType GranteeType
  accessorId   String

  action     AccessAction
  method     String
  endpoint   String
  statusCode Int

  ipAddress String?
  userAgent String?
  duration  Int?

  verified           Boolean?
  verificationResult Json?

  createdAt DateTime @default(now())

  @@index([documentId, createdAt])
  @@index([accessorType, accessorId, createdAt])
  @@index([action, createdAt])
}

// =============================================================================
// Utilities
// =============================================================================

model WebhookConfig {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name     String
  url      String
  secret   String?
  events   String[]
  isActive Boolean  @default(true)

  lastTriggeredAt DateTime?
  lastStatusCode  Int?
  failureCount    Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId, isActive])
}

model PartnerRequest {
  id           String  @id @default(cuid())
  companyName  String
  contactName  String
  contactEmail String  @unique
  website      String?

  integrationType String
  estimatedVolume Int?
  useCase         String

  status          PartnerRequestStatus @default(PENDING)
  reviewedBy      String?
  reviewNotes     String?
  rejectionReason String?

  organizationId String?       @unique
  organization   Organization? @relation(fields: [organizationId], references: [id])

  requestedAt DateTime  @default(now())
  reviewedAt  DateTime?
  approvedAt  DateTime?

  @@index([status])
  @@index([contactEmail])
}

// =============================================================================
// Enums
// =============================================================================

enum OrgType {
  ACCREDITED_PARTNER
  CLIENT
  ADMIN
}

enum OrgStatus {
  PENDING
  ACTIVE
  SUSPENDED
  INACTIVE
  REVOKED
}

enum UserRole {
  ADMIN
  PARTNER_ADMIN
  PARTNER_USER
  CLIENT_ADMIN
  CLIENT_USER
}

enum DataSource {
  MANUAL
  API
  BULK_UPLOAD
}

enum SourceTag {
  MANUAL
  PARTNER
}

enum SubmissionType {
  SINGLE
  BATCH
}

enum SubmissionStatus {
  PENDING
  PROCESSING
  SUCCESS
  PARTIAL_SUCCESS
  FAILED
}

enum ValidationStatus {
  PENDING
  VALIDATING
  PASSED
  FAILED
}

enum AuditAction {
  AUTH_LOGIN
  AUTH_LOGOUT
  AUTH_FAILED
  API_TOKEN_CREATED
  API_TOKEN_USED
  API_TOKEN_REVOKED
  ASSET_CREATED
  ASSET_UPDATED
  ASSET_DELETED
  KPI_SUBMITTED
  KPI_UPDATED
  KPI_MERGED
  SUBMISSION_CREATED
  SUBMISSION_COMPLETED
  SUBMISSION_FAILED
  BATCH_STARTED
  BATCH_COMPLETED
  VALIDATION_PASSED
  VALIDATION_FAILED
  QUEUE_ITEM_CREATED
  QUEUE_ITEM_COMPLETED
  QUEUE_ITEM_FAILED
  QUEUE_ITEM_RETRY
  QUEUE_ITEM_DEAD_LETTER
  FRAUNHOFER_REQUEST_SENT
  FRAUNHOFER_CALLBACK_RECEIVED
  FRAUNHOFER_VERIFIED
  SIGNING_REQUESTED
  SIGNING_COMPLETED
  SIGNING_FAILED
  DOCUMENT_VERIFIED
  DOCUMENT_ACCESSED
  DOCUMENT_DOWNLOADED
  ACCESS_GRANTED
  ACCESS_REVOKED
  PARTNER_REQUEST_CREATED
  PARTNER_REQUEST_APPROVED
  PARTNER_REQUEST_REJECTED
  WEBHOOK_TRIGGERED
  WEBHOOK_FAILED
  ORG_CREATED
  ORG_UPDATED
  ORG_ACTIVATED
  ORG_DELETED
  API_CREDENTIALS_CREATED
  API_CREDENTIALS_ROTATED
}

enum QueueStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  DEAD_LETTER
}

enum FraunhoferStatus {
  PENDING
  SENT
  PROCESSING
  COMPLETED
  FAILED
}

enum SigningStatus {
  PENDING
  REQUESTED
  PROCESSING
  SIGNED
  FAILED
}

enum GranteeType {
  BANK
  INVESTOR
  ORGANIZATION
}

enum AccessAction {
  STATUS_CHECK
  DOWNLOAD
  VERIFY
}

enum PartnerRequestStatus {
  PENDING
  APPROVED
  REJECTED
  REVOKED
}
